  "scripts": {
    "dev": "npx tsx watch --ignore \"server/uploads/**\" server/minimal-server.ts",
    "build": "npm run build:client && npm run build:server",
    "build:ec2": "NODE_OPTIONS='--max-old-space-size=4096' npm run build",
    "build:client": "vite build --config vite.config.minimal.ts",
    "build:server": "esbuild server/minimal-server.ts --bundle --platform=node --target=node18 --outfile=dist-server/server.js --format=esm --packages=external",
    "postinstall": "npm run build:client",
    "start": "npx tsx server/minimal-server.ts",
    "start:prod": "NODE_ENV=production node dist-server/server.js",
    "start:client": "vite preview --port 5000",
    "check": "tsc",
    "db:push": "npx drizzle-kit push",
    "db:setup": "rm -f fabzclean.db && npx tsx server/local-db-setup.ts",
    "db:reset": "rm -f fabzclean.db && npx tsx server/local-db-setup.ts",
    "db:reset-password": "npx tsx server/reset-admin-password.ts",
    "db:fix-admin": "npx tsx server/fix-admin.ts",
    "audit:security": "npm audit --audit-level=high",
    "dev:mac": "./scripts/dev-mac.sh",
    "check:dead-code": "./scripts/find-dead-code.sh",
    "check:console": "./scripts/check-console-log.sh",
    "db:check": "npx drizzle-kit push --check",
    "prepare": "husky || true",
    "test:e2e": "npx playwright test",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
